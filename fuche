#!/bin/bash
cd ~/fuche-coder
source venv/bin/activate
[ -f ~/.fuche/env ] && source ~/.fuche/env

if [ "$1" = "tts" ]; then
    shift
    # Auto-start daemon if socket is missing
    if [ ! -S /tmp/jarvis.sock ]; then
        echo "Daemon not found, starting jarvis-rs serve..."
        cd ~/projects/rust-ai/jarvis-rs && ./target/release/jarvis-rs serve --socket /tmp/jarvis.sock > /tmp/jarvis.log 2>&1 &
        echo "Waiting for model to load (tail -f /tmp/jarvis.log to watch)..."
        while [ ! -S /tmp/jarvis.sock ]; do
            if [ -f /tmp/jarvis.log ]; then
                tail -1 /tmp/jarvis.log 2>/dev/null || true
            fi
            sleep 2
        done
        echo "Daemon ready."
    fi
    python3 tts.py "$@"
else
    python3 main.py "$@"
fi
